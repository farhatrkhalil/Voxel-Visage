<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:scrollbarAlwaysDrawVerticalTrack="true">

    <PreferenceCategory
        android:title="@string/user_settings_title"
        app:iconSpaceReserved="false">

        <CheckBoxPreference
            app:iconSpaceReserved="true"
            android:key="darkMode"
            android:icon="@drawable/darkmode_dark"
            android:title="Dark Mode"
            android:summaryOn="Dark mode enabled"
            android:summaryOff="Dark mode disabled" />

    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false">

        <Preference
            android:title="Developers"
            android:icon="@drawable/developers_dark"
            android:summary="Meet the talented developers behind this app"
            android:key="developers_info"/>

        <Preference
            android:title="Privacy Policy"
            android:icon="@drawable/privacypolicy_dark"
            android:summary="View our privacy policy"
            android:key="privacy_policy"/>

        <Preference
            app:iconSpaceReserved="true"
            android:title="App License"
            android:icon="@drawable/license_dark"
            android:summary="This app is licensed under the MIT License.Thank you for using our app!"
            android:key="license"/>

        <Preference
            android:title="App Version"
            android:icon="@drawable/version_dark"
            android:summary="1.0"
            android:key="version"/>

    </PreferenceCategory>

</PreferenceScreen>
