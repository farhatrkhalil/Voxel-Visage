<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.example.voxelvisage.ui.settings.SettingsFragment"
        android:label="@string/app_name" />

    <fragment
        android:id="@+id/navigation_camera"
        android:name="com.example.voxelvisage.ui.camera.CameraFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_camera" />
    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.voxelvisage.ui.home.HomeFragment"
        android:label="navigation_home" />

    <activity
        android:id="@+id/navigation_gallery"
        android:name="com.example.voxelvisage.GalleryViewerActivity"
        android:label="navigation_gallery" />

</navigation>